rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isValidUserStats(data) {
      return data.keys().hasAll(['displayName', 'totalReps', 'lastWorkoutAt']) 
        && data.displayName is string && data.displayName.size() <= 100
        && data.totalReps is number
        && data.lastWorkoutAt == request.time
        && (!('photoURL' in data.keys()) || (data.photoURL is string && data.photoURL.size() <= 500));
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUserStats(incoming())
        && incoming().totalReps >= 0;
        
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserStats(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['totalReps', 'lastWorkoutAt', 'displayName', 'photoURL'])
        && incoming().totalReps >= existing().totalReps;
    }
  }
}
